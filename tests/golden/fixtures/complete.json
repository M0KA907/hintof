  "ingredientGroups": [
    {
      "name": "Custard",
      "ingredients": [
        {
          "qty": { "kind": "single", "value": { "n": 2, "d": 1 } },
          "unit": "cups",
          "item": "heavy cream"
        },
        { "item": "1 vanilla bean", "note": "split and scraped" },
        { "qty": { "kind": "single", "value": { "n": 5, "d": 1 } }, "item": "egg yolks" },
        { "qty": { "kind": "single", "value": { "n": 1, "d": 2 } }, "unit": "cup", "item": "sugar" }
      ]
    },
    {
      "name": "Topping",
      "ingredients": [
        {
          "qty": { "kind": "single", "value": { "n": 6, "d": 1 } },
          "unit": "tbsp",
          "item": "sugar",
          "note": "for the caramel"
        }
      ]
    }
  ],
  "stepSections": [
    {
      "name": "Prep",
      "steps": [
        "Heat the cream with the vanilla until steaming; steep 15 min.",
        "Whisk yolks and sugar until pale."
      ]
    },
    {
      "name": "Bake",
      "steps": [
        "Temper the yolks, strain, divide into ramekins.",
        "Bake in a water bath at 325°F for 40 min, until just set."
      ]
    }
  ],
  "notes": "Chill at least 2 hours before torching.",
  "substitutions": [{ "from": "vanilla bean", "to": "1 tsp vanilla extract" }],
  "storage": "Keeps 3 days covered in the fridge; torch just before serving.",
  "equipment": ["6 ramekins", "kitchen torch"],
